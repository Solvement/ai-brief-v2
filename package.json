{
  "name": "ai-brief",
  "private": true,
  "version": "0.1.0",
  "description": "AI-brief: a Chinese-first AI intelligence product turning AI news, models, tools, projects, papers, and guides into a daily decision workflow.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.mjs",
    "test": "tsc -p tsconfig.test.json && node scripts/run-tests.mjs",
    "validate": "node scripts/validate-content.mjs",
    "validate:content": "node scripts/validate-content.mjs",
    "validate:evaluation": "npm test",
    "validate:playbook": "npm test",
    "preview": "vite preview --host 127.0.0.1",
    "ingest:live": "node --no-warnings scripts/live-ingest.mjs",
    "db:init": "node --no-warnings scripts/db-init.mjs",
    "db:reset": "node --no-warnings scripts/db-reset.mjs"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  }
}
