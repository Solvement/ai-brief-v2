{
  "name": "ai-brief",
  "private": true,
  "version": "0.3.0",
  "description": "Chinese-first AI briefings for GitHub projects, model evolution, product updates, and actionable AI learning.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "brief:lint": "node scripts/brief/lint.mjs brief-wiki",
    "brief:build": "node scripts/brief/build.mjs brief-wiki",
    "brief:init": "node scripts/brief/wiki.mjs init brief-wiki",
    "predev": "node --no-warnings scripts/maybe-ingest.mjs",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "typecheck:scripts": "tsc -p scripts/jsconfig.json",
    "lint:eslint": "eslint app src scripts",
    "lint:content": "node scripts/lint.mjs",
    "lint": "npm run lint:eslint && npm run lint:content",
    "verify": "npm run lint && npm run test && npm run build",
    "validate": "node scripts/validate-text-encoding.mjs && node scripts/validate-trending.mjs && node scripts/validate-models.mjs && node scripts/validate-articles.mjs && node scripts/validate-papers-radar.mjs && node scripts/validate-pipeline-status.mjs && node scripts/validate-papers-deepread.mjs && node scripts/validate-daily-digest.mjs && node scripts/validate-mind-palace.mjs",
    "digest:daily": "node --env-file-if-exists=.env.local --no-warnings scripts/columns/digest/daily.mjs",
    "test": "node --test scripts/**/*.test.mjs && npm run validate",
    "preview": "next start",
    "ingest": "node --no-warnings scripts/ingest.mjs",
    "ingest:force": "node --no-warnings scripts/ingest.mjs --no-cache",
    "ingest:dry": "node --no-warnings scripts/ingest.mjs --dry-run",
    "papers:discover": "node --no-warnings scripts/papers-radar.mjs discover",
    "papers:triage": "node --no-warnings scripts/papers-radar.mjs triage",
    "papers:review": "node --no-warnings scripts/papers-radar.mjs review",
    "papers:daily": "node --no-warnings scripts/columns/papers/daily.mjs",
    "papers:run": "node --no-warnings scripts/columns/papers/daily.mjs",
    "papers:codex-deepdive": "node --no-warnings scripts/columns/papers/codex-deepdive.mjs",
    "papers:curate": "node --no-warnings scripts/columns/papers/curate.mjs",
    "papers:select": "node --no-warnings --env-file=.env.local scripts/columns/papers/select.mjs",
    "papers:hf": "npm run papers:curate && npm run papers:select",
    "papers:deepread": "claude -p --model claude-opus-4-8 --dangerously-skip-permissions \"Read and follow docs/superpowers/specs/daily-deepread-prompt.md to author today's paper deep-reads (full-text grounded, Chinese, honest), then run build-index + validate. Do not git push.\"",
    "papers:cold-audit": "node --no-warnings scripts/columns/papers/cold-audit/run-daily.mjs",
    "papers:cold-audit:grandfather": "node --no-warnings scripts/columns/papers/cold-audit/run-daily.mjs --grandfather",
    "kg:ingest": "node --no-warnings scripts/kg/ingest-daily.mjs",
    "kg:research": "node --no-warnings scripts/kg/research-loop.mjs",
    "kg:vocab": "node --no-warnings scripts/kg/concept-vocab.mjs",
    "kg:build": "node --no-warnings scripts/kg/build-brief-graph.mjs && node --no-warnings scripts/kg/integrate-kg.mjs && npm run kg:vocab && node --no-warnings scripts/kg/embed.mjs",
    "kg:build-legacy": "node --no-warnings scripts/kg/build-knowledge-graph.mjs",
    "daily": "node --env-file-if-exists=.env.local --no-warnings scripts/daily.mjs",
    "news:daily": "node --no-warnings scripts/columns/news/daily.mjs",
    "projects:daily": "node --no-warnings scripts/columns/projects/daily.mjs",
    "projects:codex-deepdive": "node --no-warnings scripts/columns/projects/codex-deepdive.mjs",
    "models:check": "node --no-warnings scripts/columns/models/sources.mjs",
    "models:generate": "node --no-warnings scripts/columns/models/generate.mjs",
    "models:daily": "node --no-warnings scripts/columns/models/daily.mjs",
    "pipeline:sync": "node --no-warnings scripts/sync-pipeline-status.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@supabase/supabase-js": "^2.107.0",
    "jsonrepair": "^3.14.0",
    "mermaid": "^11.15.0",
    "next": "^16.2.7",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^16.5.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.1"
  }
}
