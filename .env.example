# Placeholder only. Do not commit real values.
# Fill these in via OS env / direnv / secret manager.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# Optional: GitHub Projects refresh.
# Light pass scores and summarizes all trending repos; deep pass analyzes selected high-value repos.
PROJECT_LIGHT_MODEL=deepseek-v4-flash
PROJECT_DEEP_MODEL=deepseek-v4-pro
PROJECT_LIGHT_MAX_TOKENS=1200
PROJECT_DEEP_MAX_TOKENS=8000

# Optional: AI Job Research Radar.
# Triage should stay cheap; review can point at your DeepSeek V4 Pro deployment name.
PAPERS_TRIAGE_MODEL=deepseek-v4-flash
PAPERS_REVIEW_MODEL=deepseek-v4-pro

# Optional: curated model/archive analysis when a model pipeline is added.
MODEL_ANALYSIS_MODEL=deepseek-v4-pro
VERIFY_MODEL=deepseek-v4-flash

# GitHub token (raises rate limit when fetching READMEs). Optional but recommended.
GITHUB_TOKEN=

# Optional: dev startup re-ingests if public/data/trending.json is older than this.
INGEST_INTERVAL_HOURS=18

# Required to authorize POST /api/models/refresh and /api/models/analyze.
# Any non-empty secret string; clients send it in the JSON body as `token`.
# When unset, both endpoints deny every request (fail closed).
REFRESH_TOKEN=
